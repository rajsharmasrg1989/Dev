pipeline {
    agent any
 environment {
 
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout Code') {
            steps {
                // Check out your repository from GitHub
               git url: 'https://github.com/rajsharmasrg1989/Dev.git', branch: 'main'
            }
}
stage('Install Dependencies') {
            steps {
                sh '''

                python3 -m venv venv
                . venv/bin/activate
                pip install -r requirements.txt
                '''
            }
        }

        

        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t python-app:${IMAGE_TAG} .
               
                """
            }
        }
        }
    }


