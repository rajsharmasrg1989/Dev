pipeline {
    agent any 

  environment {
        DOCKER_IMAGE = "rajsra1989/python-app"
        AWS_REGION = "ap-south-1"
        EKS_CLUSTER = "deveks"
    }


    stages {
        stage('Checkout Code') {
            steps {
                // Check out your repository from GitHub
               git url: 'https://github.com/rajsharmasrg1989/Dev.git', branch: 'main'
            }
}
stage('Install Dependencies') {
            steps {
                sh '''

                python3 -m venv venv
                . venv/bin/activate
                pip install -r requirements.txt
                '''
            }
        }

        
   stage('Build Docker Image') {
            steps {
                script {
                    sh "docker build -t $DOCKER_IMAGE:${BUILD_NUMBER} ."
                }
            }
        }

stage('Login to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'USERNAME',
                    passwordVariable: 'PASSWORD'
                )]) {
                    sh "echo $PASSWORD | docker login -u $USERNAME --password-stdin"
                }
            }
        }

        stage('Push Image') {
            steps {
                script {
                    sh """
                    docker push $DOCKER_IMAGE:${BUILD_NUMBER}
                    docker tag $DOCKER_IMAGE:${BUILD_NUMBER} $DOCKER_IMAGE:latest
                    docker push $DOCKER_IMAGE:latest
                    """
                }
            }
        }
    stage('Configure AWS & EKS') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds']]) {

                    sh """
                    aws eks update-kubeconfig \
                      --region $AWS_REGION \
                      --name $EKS_CLUSTER
                    """
                }
            }
        }

stage('Install kubectl') {
    steps {
        sh 'curl -LO "https://storage.googleapis.com(curl -s https://storage.googleapis.com)/bin/linux/amd64/kubectl"'
        sh 'chmod +x ./kubectl'
        sh 'sudo mv ./kubectl /usr/local/bin/kubectl' // Move to a directory in PATH
    }
}

        stage('Deploy to EKS') {
            steps {
                sh """
                kubectl set image deployment/python-app \
                python-app=$DOCKER_IMAGE:${BUILD_NUMBER} --record || \
                kubectl apply -f k8s/deployment.yaml

                kubectl apply -f k8s/service.yaml
                """
            }
        }

        stage('Verify Deployment') {
            steps {
                sh "kubectl rollout status deployment/python-app"
            }
        }



        }
    }


